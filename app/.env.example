# Copy this to .env for local development
# In EKS: these are injected by External Secrets Operator from AWS Secrets Manager

PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
APP_VERSION=1.0.0

# Database — for local dev use docker-compose values
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tododb
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MAX=10
DB_SSL=false

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000
