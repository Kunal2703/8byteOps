# ─────────────────────────────────────────────────────────────────────────────
# CI/CD Secrets — copy to .env.ci and fill in values
# NEVER commit .env.ci to git
# ─────────────────────────────────────────────────────────────────────────────

# GitHub PAT — used by workflows to checkout code and post PR comments
# Create at: https://github.com/settings/tokens
# Required scopes: repo, workflow
GH_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AWS credentials — used by workflows to push to ECR and deploy to EKS
# Create IAM user with ECR + EKS permissions
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Slack webhook — used for deploy notifications
# Create at: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# AWS config
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=283800772211
